// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  output        = "../app/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"] // Farklı işletim sistemleri için binary desteği sağlar
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ALUMNI
  MODERATOR
  ADMIN
  USER // Default fallback
  ACADEMICIAN
  HEAD_OF_DEPARTMENT
}

// Üye onay durumu
enum ApprovalStatus {
  PENDING   // Onay bekliyor (kayıt sonrası)
  APPROVED  // Onaylandı
  REJECTED  // Reddedildi
}

// Çalışma durumu
enum EmploymentStatus {
  EMPLOYED_OWN_SECTOR   // Kendi sektöründe çalışıyor
  EMPLOYED_OTHER_SECTOR // Başka sektörde çalışıyor
  UNEMPLOYED            // İşsiz
  STUDENT              // Öğrenime devam ediyor
  SELF_EMPLOYED        // Serbest / Girişimci
}

// İlan türleri
enum JobType {
  JOB           // İş ilanı (mezun paylaşır)
  INTERNSHIP    // Staj ilanı (mezun/şirket)
  INTERNSHIP_REQUEST // Staj talebi (öğrenci arar)
  JOB_SEARCH    // İş arayışı (mezun/öğrenci)
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JobStatus {
  OPEN
  CLOSED
}

// Profil görünürlük ayarları (Belge 4.2.3)
enum ProfileVisibility {
  PUBLIC     // Herkese açık
  REGISTERED // Sadece kayıtlı kullanıcılar
  PRIVATE    // Gizli
}

// ─── Bölüm/Program modelleri (Admin tarafından yönetilir) ───────────────────

model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String?   @unique // Bölüm kodu (ör. BT, EO)
  description String?
  isActive    Boolean   @default(true)

  programs    Program[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Program {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  isActive     Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([departmentId, name])
}

// ────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String    @unique
  password      String
  emailVerified DateTime?
  role          UserRole  @default(USER)
  image         String?
  coverImage    String?
  phoneNumber   String?   @unique

  // Profil alanları (Belge 4.2)
  bio               String? // Kısa biyografi
  cvUrl             String? // CV dosya yolu (PDF)
  profileVisibility ProfileVisibility @default(PUBLIC)

  // Üye onay akışı
  approvalStatus ApprovalStatus @default(PENDING)
  approvedAt     DateTime?
  approvedById   String? // Onaylayan bölüm başkanı/admin ID

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?
  deletedAt DateTime? // KVKK uyumu için Soft Delete
  isActive  Boolean   @default(true) // Hesap dondurma özelliği

  // Existing relations
  moreinfo Info?
  accounts Account[]
  sessions Session[]

  // New relations from UML
  student          Student?
  alumni           Alumni?
  academician      Academician?
  headOfDepartment HeadOfDepartment?
  admin            Admin?
  moderator        Moderator?

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  organizedEvents Event[]

  experiences Experience[]
  educations  Education[]
  skills      Skill[]

  jobAdvertisements JobAdvertisement[]

  // Duyurular
  authoredAnnouncements Announcement[] @relation("AnnouncementsAuthored")

  // Raporlama ve Denetim (Yeni Eklenenler)
  submittedReports Report[]   @relation("ReportSubmitted")
  auditLogs        AuditLog[] @relation("UserAuditLogs")

  @@index([approvalStatus])
  @@index([role, approvalStatus])
}

model Experience {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  company     String
  location    String?
  startDate   DateTime
  endDate     DateTime? // Null if currently working
  current     Boolean   @default(false)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Education {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  school       String
  degree       String
  fieldOfStudy String
  startDate    DateTime
  endDate      DateTime?
  current      Boolean   @default(false)
  description  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Yetenekler modeli (Belge 4.2.1)
model Skill {
  id     String @id @default(cuid())
  name   String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, name]) // Aynı kullanıcı aynı yeteneği bir kez ekleyebilir
}

model Student {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  studentNo        String   @unique
  department       String
  schoolEmail      String?  // Okul e-postası (ör. 123456@aacomyo.edu.tr)
  interests        String[] // Array of strings
  referenceTeacher String?  // Referans hoca adı

  applications       JobApplication[]
  mentorshipRequests MentorshipRequest[]
}

model HeadOfDepartment {
  id         String @id @default(cuid())
  userId     String @unique
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  department String
  title      String
}

model Alumni {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  graduationYear   Int
  department       String? // Bölüm adı

  // Mesleki bilgiler
  currentPosition  String          @default("")
  employmentStatus EmploymentStatus? // Çalışma durumu
  employmentSector String?          // Çalışılan sektör (serbest metin)

  // Onay akışı
  referenceTeacher String?  // Referans hoca adı (kayıt sırasında)
  studentNo        String?  // Opsiyonel okul numarası

  competencies     String[]
  mentorshipTopics String[]

  mentorshipRequests MentorshipRequest[]
}

model Academician {
  id         String @id @default(cuid())
  userId     String @unique
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  department String
  title      String
}


model Admin {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Moderator {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobAdvertisement {
  id          String    @id @default(cuid())
  title       String
  description String    // Kısa açıklama / özet
  content     String?   @db.Text // Detaylı içerik (markdown/zengin metin)
  location    String    @default("")
  type        JobType
  status      JobStatus @default(OPEN)
  externalLink String?  // Harici bağlantı (şirket sayfası, başvuru linki vb.)
  tags        String[]  // Etiketler (ör: ["Python", "Uzaktan"])
  publisherId String
  publisher   User      @relation(fields: [publisherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications JobApplication[]

  @@index([type, status])
  @@index([publisherId])
  @@index([createdAt])
}

model JobApplication {
  id              String            @id @default(cuid())
  applicationDate DateTime          @default(now())
  status          ApplicationStatus @default(PENDING)
  coverLetter     String?

  jobId String
  job   JobAdvertisement @relation(fields: [jobId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

model MentorshipRequest {
  id          String        @id @default(cuid())
  status      RequestStatus @default(PENDING)
  requestType String

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  alumniId String
  alumni   Alumni @relation(fields: [alumniId], references: [id])
}

// Etkinlik türleri
enum EventType {
  CAREER_FAIR  // Kariyer Fuarı
  NETWORKING   // Networking Etkinliği
  WORKSHOP     // Atölye
  SEMINAR      // Seminer
  CONFERENCE   // Konferans
  MEETUP       // Buluşma
  OTHER        // Diğer
}

// Etkinlik durumları
enum EventStatus {
  UPCOMING   // Yaklaşan
  ONGOING    // Devam Eden
  COMPLETED  // Tamamlandı
  CANCELLED  // İptal Edildi
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String
  date        DateTime
  endDate     DateTime?   // Opsiyonel bitiş tarihi
  location    String
  type        EventType   @default(OTHER)
  status      EventStatus @default(UPCOMING)
  capacity    Int?        // Maksimum katılımcı sayısı
  image       String?     // Etkinlik görseli

  organizerId String
  organizer   User   @relation(fields: [organizerId], references: [id])

  participants EventParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Etkinlik katılımcıları
model EventParticipant {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  status  String @default("REGISTERED") // REGISTERED, ATTENDED, CANCELLED

  createdAt DateTime @default(now())

  @@unique([eventId, userId]) // Aynı kullanıcı aynı etkinliğe bir kez kayıt olabilir
}

model EducationRecommendation {
  id             String @id @default(cuid())
  department     String
  suggestedPaths String
  frequencyScore Float
}

model Message {
  id        String   @id @default(cuid())
  content   String
  timestamp DateTime @default(now())

  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

// Existing models preserved
model Info {
  id          String @id @default(cuid())
  userId      String @unique
  firstName   String
  lastName    String
  phoneNumber String
  email       String
  image       String
  company     String
  position    String
  location    String
  about       String
  website     String
  linkedin    String
  github      String
  twitter     String
  instagram   String
  youtube     String
  facebook    String
  telegram    String
  discord     String
  twitch      String
  tiktok      String

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// Bildirim türleri
enum NotificationType {
  MESSAGE       // Yeni mesaj
  JOB_APPLICATION // İş başvurusu durumu
  EVENT         // Etkinlik hatırlatması
  MENTORSHIP    // Mentorluk talebi
  SYSTEM        // Sistem bildirimi
  APPROVAL      // Üyelik onay bildirimi
}

// Bildirimler modeli (Belge 4.4)
model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  title   String
  message String
  link    String?          // Tıklandığında gidilecek sayfa
  isRead  Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// Şikâyet / Raporlama modeli (Belge 4.7.4)
enum ReportType {
  USER_PROFILE
  JOB_POSTING
  MESSAGE
  EVENT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model Report {
  id         String @id @default(cuid())
  reporterId String // Şikâyet eden kullanıcı
  reporter   User   @relation("ReportSubmitted", fields: [reporterId], references: [id])

  reportedId  String // Şikâyet edilen içerik/kullanıcı ID'si
  type        ReportType
  reason      String     // Şikâyet nedeni
  description String?    // Ek açıklama

  status      ReportStatus @default(PENDING)
  actionTaken String?      // Moderatörün aldığı aksiyon notu

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reporterId])
  @@index([type, status])
}

// Sistem Denetim İzleri (Audit Logs) (Belge 4.7.6 & 5.9)
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ROLE_CHANGE
  ACCOUNT_SUSPEND
}

model AuditLog {
  id     String  @id @default(cuid())
  userId String? // İşlemi yapan kullanıcı (Anonim işlemler için null olabilir)
  user   User?   @relation("UserAuditLogs", fields: [userId], references: [id])

  action     AuditAction
  entityType String  // Hangi tablo/modül üzerinde işlem yapıldı (örn: "JOB", "USER")
  entityId   String? // İlgili kaydın ID'si
  details    String? // Değişiklik detayları (JSON formatında saklanabilir)
  ipAddress  String? // İşlemin yapıldığı IP adresi

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action, entityType])
  @@index([createdAt])
}

// Duyuru / Haberler Modeli
model Announcement {
  id       String  @id @default(cuid())
  title    String
  content  String  @db.Text
  imageUrl String?
  isPinned Boolean @default(false) // Sabitlenmiş duyuru

  authorId String
  author   User   @relation("AnnouncementsAuthored", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([isPinned])
}
